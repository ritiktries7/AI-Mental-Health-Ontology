<?xml version="1.0" encoding="UTF-8"?>

<!--
  ============================================================
  Ontology   : Mental Health Depression Analysis Ontology (MHDAO)
  Version    : 1.0.0
  Author     : AI-Assisted Ontology Engineering
  Description: OWL ontology for explainable AI-based depression
               detection using TF-IDF + Logistic Regression model
               combined with semantic reasoning.
  Dataset    : Reddit mental health statements (~7731 entries,
               balanced classes: 3831 depressed / 3900 non-depressed)
  Compatible : Protégé 5.x, OWL 2 DL
  Namespace  : https://www.mhda-ontology.org/mhda#
  ============================================================
-->

<!DOCTYPE rdf:RDF [
  <!ENTITY owl  "http://www.w3.org/2002/07/owl#">
  <!ENTITY rdf  "http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#">
  <!ENTITY xsd  "http://www.w3.org/2001/XMLSchema#">
  <!ENTITY dc   "http://purl.org/dc/elements/1.1/">
  <!ENTITY mhda "https://www.mhda-ontology.org/mhda#">
]>

<rdf:RDF
  xmlns:owl  ="http://www.w3.org/2002/07/owl#"
  xmlns:rdf  ="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:rdfs ="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:xsd  ="http://www.w3.org/2001/XMLSchema#"
  xmlns:dc   ="http://purl.org/dc/elements/1.1/"
  xmlns:mhda ="https://www.mhda-ontology.org/mhda#"
  xml:base   ="https://www.mhda-ontology.org/mhda">

  <!-- ============================================================
       O N T O L O G Y   H E A D E R
       ============================================================ -->

  <owl:Ontology rdf:about="https://www.mhda-ontology.org/mhda">
    <rdfs:label xml:lang="en">Mental Health Depression Analysis Ontology</rdfs:label>
    <rdfs:comment xml:lang="en">
      An OWL 2 DL ontology for explainable AI-based depression detection.
      Combines TF-IDF + Logistic Regression predictions with semantic
      reasoning to surface explanations such as
      "High risk due to fatigue and social isolation."
      Grounded in a Reddit dataset of 7,731 labeled mental health statements.
    </rdfs:comment>
    <dc:creator>Mental Health AI Project</dc:creator>
    <dc:description>Ontology for depression symptom extraction, mapping, and explainable risk prediction.</dc:description>
    <owl:versionInfo>1.0.0</owl:versionInfo>
    <owl:imports rdf:resource="http://www.w3.org/2002/07/owl"/>
  </owl:Ontology>


  <!-- ============================================================
       C L A S S   H I E R A R C H Y
       ============================================================
       Top-level classes:
         MentalHealthCondition
           └── Depression
               └── MajorDepressiveDisorder
               └── PersistentDepressiveDisorder
         Symptom
           ├── EmotionalSymptom
           │     ├── Sadness, Hopelessness, Anhedonia, Guilt, Worthlessness
           ├── CognitiveSymptom
           │     ├── ConcentrationDifficulty, NegativeThinking, SuicidalIdeation
           ├── BehavioralSymptom
           │     ├── SocialIsolation, Withdrawal, SleepDisturbance, Avoidance
           ├── PhysicalSymptom
           │     ├── Fatigue, Psychomotor, AppetiteChange
           └── SocialSymptom
                 ├── Isolation, Loneliness
         Emotion (affective states, not necessarily clinical symptoms)
         Behavior (observable behavioral patterns)
         UserInput (text submitted for analysis)
         Prediction (model output)
         MLModel (the TF-IDF + Logistic Regression predictor)
         ExplainabilityReport (human-readable explanation of a prediction)
       ============================================================ -->

  <!-- ─── MentalHealthCondition ─────────────────────────────── -->

  <owl:Class rdf:about="&mhda;MentalHealthCondition">
    <rdfs:label xml:lang="en">Mental Health Condition</rdfs:label>
    <rdfs:comment xml:lang="en">
      Any clinically recognised mental disorder or psychological condition.
      Serves as the root of the condition hierarchy.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;Depression">
    <rdfs:subClassOf rdf:resource="&mhda;MentalHealthCondition"/>
    <rdfs:label xml:lang="en">Depression</rdfs:label>
    <rdfs:comment xml:lang="en">
      A mood disorder characterised by persistent sadness, loss of interest,
      fatigue, and related symptoms. Primary target condition for this ontology.
    </rdfs:comment>
    <!-- OWL Restriction: Depression is indicated by at least 3 Symptoms -->
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="&mhda;isIndicatedBy"/>
        <owl:minCardinality rdf:datatype="&xsd;nonNegativeInteger">3</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="&mhda;MajorDepressiveDisorder">
    <rdfs:subClassOf rdf:resource="&mhda;Depression"/>
    <rdfs:label xml:lang="en">Major Depressive Disorder</rdfs:label>
    <rdfs:comment xml:lang="en">
      Clinical MDD: depressed mood or anhedonia for ≥2 weeks, with ≥5 DSM-5 criteria.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;PersistentDepressiveDisorder">
    <rdfs:subClassOf rdf:resource="&mhda;Depression"/>
    <rdfs:label xml:lang="en">Persistent Depressive Disorder (Dysthymia)</rdfs:label>
    <rdfs:comment xml:lang="en">
      Chronic depressed mood lasting ≥2 years, less severe than MDD.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;Anxiety">
    <rdfs:subClassOf rdf:resource="&mhda;MentalHealthCondition"/>
    <rdfs:label xml:lang="en">Anxiety Disorder</rdfs:label>
    <rdfs:comment xml:lang="en">
      Conditions characterised by excessive worry, fear, or nervousness.
      Frequently co-morbid with Depression.
    </rdfs:comment>
  </owl:Class>

  <!-- ─── Symptom (root) ────────────────────────────────────── -->

  <owl:Class rdf:about="&mhda;Symptom">
    <rdfs:label xml:lang="en">Symptom</rdfs:label>
    <rdfs:comment xml:lang="en">
      An observable or reported sign of a mental health condition.
      Extracted from user text by keyword matching or NLP models.
    </rdfs:comment>
  </owl:Class>

  <!-- ─── EmotionalSymptom ──────────────────────────────────── -->

  <owl:Class rdf:about="&mhda;EmotionalSymptom">
    <rdfs:subClassOf rdf:resource="&mhda;Symptom"/>
    <rdfs:label xml:lang="en">Emotional Symptom</rdfs:label>
    <rdfs:comment xml:lang="en">Symptoms primarily affecting mood and emotional state.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;Sadness">
    <rdfs:subClassOf rdf:resource="&mhda;EmotionalSymptom"/>
    <rdfs:label xml:lang="en">Sadness</rdfs:label>
    <rdfs:comment xml:lang="en">
      Persistent low mood; feeling deeply unhappy, tearful, or empty.
      Keyword indicators: sad, cry, tears, miserable, grief, sorrow.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;Hopelessness">
    <rdfs:subClassOf rdf:resource="&mhda;EmotionalSymptom"/>
    <rdfs:label xml:lang="en">Hopelessness</rdfs:label>
    <rdfs:comment xml:lang="en">
      Belief that nothing will improve; lack of positive expectations.
      Keyword indicators: hopeless, no point, nothing matters, futile, useless.
      Strong predictor of MDD and suicidal ideation in dataset.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;Anhedonia">
    <rdfs:subClassOf rdf:resource="&mhda;EmotionalSymptom"/>
    <rdfs:label xml:lang="en">Anhedonia</rdfs:label>
    <rdfs:comment xml:lang="en">
      Inability to feel pleasure from previously enjoyable activities.
      Keyword indicators: can't enjoy, no interest, don't care, numb, empty.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;Guilt">
    <rdfs:subClassOf rdf:resource="&mhda;EmotionalSymptom"/>
    <rdfs:label xml:lang="en">Guilt</rdfs:label>
    <rdfs:comment xml:lang="en">
      Excessive or inappropriate guilt, self-blame.
      Keyword indicators: my fault, blame myself, guilty, deserve this.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;Worthlessness">
    <rdfs:subClassOf rdf:resource="&mhda;EmotionalSymptom"/>
    <rdfs:label xml:lang="en">Worthlessness</rdfs:label>
    <rdfs:comment xml:lang="en">
      Feeling of having no value or being a burden to others.
      Keyword indicators: worthless, useless, burden, failure, loser.
    </rdfs:comment>
  </owl:Class>

  <!-- ─── CognitiveSymptom ──────────────────────────────────── -->

  <owl:Class rdf:about="&mhda;CognitiveSymptom">
    <rdfs:subClassOf rdf:resource="&mhda;Symptom"/>
    <rdfs:label xml:lang="en">Cognitive Symptom</rdfs:label>
    <rdfs:comment xml:lang="en">Symptoms affecting thinking, concentration, and reasoning.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;ConcentrationDifficulty">
    <rdfs:subClassOf rdf:resource="&mhda;CognitiveSymptom"/>
    <rdfs:label xml:lang="en">Concentration Difficulty</rdfs:label>
    <rdfs:comment xml:lang="en">
      Trouble focusing, making decisions, or remembering things.
      Keyword indicators: can't focus, brain fog, forgetful, distracted.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;NegativeThinking">
    <rdfs:subClassOf rdf:resource="&mhda;CognitiveSymptom"/>
    <rdfs:label xml:lang="en">Negative Thinking</rdfs:label>
    <rdfs:comment xml:lang="en">
      Persistent pessimistic thoughts about self, world, or future.
      Keyword indicators: nothing works, always fail, hate myself, dark thoughts.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;SuicidalIdeation">
    <rdfs:subClassOf rdf:resource="&mhda;CognitiveSymptom"/>
    <rdfs:label xml:lang="en">Suicidal Ideation</rdfs:label>
    <rdfs:comment xml:lang="en">
      Thoughts of self-harm, death, or suicide.
      CRITICAL RISK INDICATOR: presence of this symptom should
      immediately elevate risk score to HIGH regardless of other features.
      Keyword indicators: suicide, end it, don't want to live, kill myself.
    </rdfs:comment>
  </owl:Class>

  <!-- ─── BehavioralSymptom ─────────────────────────────────── -->

  <owl:Class rdf:about="&mhda;BehavioralSymptom">
    <rdfs:subClassOf rdf:resource="&mhda;Symptom"/>
    <rdfs:label xml:lang="en">Behavioral Symptom</rdfs:label>
    <rdfs:comment xml:lang="en">Symptoms expressed through changed patterns of action or inaction.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;SocialIsolation">
    <rdfs:subClassOf rdf:resource="&mhda;BehavioralSymptom"/>
    <rdfs:label xml:lang="en">Social Isolation</rdfs:label>
    <rdfs:comment xml:lang="en">
      Actively withdrawing from or avoiding social contact.
      Keyword indicators: alone, isolate, avoid people, no friends, stay home.
      Very prominent in Reddit dataset — appeared in majority of depressed posts.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;Withdrawal">
    <rdfs:subClassOf rdf:resource="&mhda;BehavioralSymptom"/>
    <rdfs:label xml:lang="en">Social Withdrawal</rdfs:label>
    <rdfs:comment xml:lang="en">
      Gradual disengagement from social activities or relationships.
      Related to SocialIsolation but reflects process rather than state.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;SleepDisturbance">
    <rdfs:subClassOf rdf:resource="&mhda;BehavioralSymptom"/>
    <rdfs:label xml:lang="en">Sleep Disturbance</rdfs:label>
    <rdfs:comment xml:lang="en">
      Insomnia, hypersomnia, or disrupted sleep patterns.
      Both staying up all night (avoidance) and sleeping too much are documented
      in the Reddit dataset as behavioral signals of depression.
      Keyword indicators: can't sleep, insomnia, sleep all day, nightmares.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;Avoidance">
    <rdfs:subClassOf rdf:resource="&mhda;BehavioralSymptom"/>
    <rdfs:label xml:lang="en">Avoidance</rdfs:label>
    <rdfs:comment xml:lang="en">
      Deliberately avoiding people, places, or responsibilities.
      Keyword indicators: avoid, can't face, not going, hiding.
    </rdfs:comment>
  </owl:Class>

  <!-- ─── PhysicalSymptom ───────────────────────────────────── -->

  <owl:Class rdf:about="&mhda;PhysicalSymptom">
    <rdfs:subClassOf rdf:resource="&mhda;Symptom"/>
    <rdfs:label xml:lang="en">Physical Symptom</rdfs:label>
    <rdfs:comment xml:lang="en">Symptoms manifesting in the body or physical functioning.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;Fatigue">
    <rdfs:subClassOf rdf:resource="&mhda;PhysicalSymptom"/>
    <rdfs:label xml:lang="en">Fatigue</rdfs:label>
    <rdfs:comment xml:lang="en">
      Persistent exhaustion or loss of energy not explained by physical illness.
      Keyword indicators: tired, exhausted, no energy, worn out, drained.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;AppetiteChange">
    <rdfs:subClassOf rdf:resource="&mhda;PhysicalSymptom"/>
    <rdfs:label xml:lang="en">Appetite Change</rdfs:label>
    <rdfs:comment xml:lang="en">
      Significant increase or decrease in appetite or weight.
      Keyword indicators: not eating, overeating, lost weight, no appetite.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;PsychomotorChange">
    <rdfs:subClassOf rdf:resource="&mhda;PhysicalSymptom"/>
    <rdfs:label xml:lang="en">Psychomotor Change</rdfs:label>
    <rdfs:comment xml:lang="en">
      Observable slowing (retardation) or agitation in movement and speech.
      Keyword indicators: slow, sluggish, restless, agitated.
    </rdfs:comment>
  </owl:Class>

  <!-- ─── SocialSymptom ─────────────────────────────────────── -->

  <owl:Class rdf:about="&mhda;SocialSymptom">
    <rdfs:subClassOf rdf:resource="&mhda;Symptom"/>
    <rdfs:label xml:lang="en">Social Symptom</rdfs:label>
    <rdfs:comment xml:lang="en">Symptoms relating to social functioning and relationships.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;Isolation">
    <rdfs:subClassOf rdf:resource="&mhda;SocialSymptom"/>
    <rdfs:label xml:lang="en">Isolation</rdfs:label>
    <rdfs:comment xml:lang="en">
      Subjective sense of being cut off from others; overlaps with SocialIsolation
      but focuses on the felt experience rather than the behavior.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;Loneliness">
    <rdfs:subClassOf rdf:resource="&mhda;SocialSymptom"/>
    <rdfs:label xml:lang="en">Loneliness</rdfs:label>
    <rdfs:comment xml:lang="en">
      Painful sense of being alone or disconnected from others.
      Keyword indicators: lonely, no one cares, no friends, alone.
    </rdfs:comment>
  </owl:Class>

  <!-- ─── Stress (cross-cutting) ────────────────────────────── -->

  <owl:Class rdf:about="&mhda;Stress">
    <rdfs:subClassOf rdf:resource="&mhda;EmotionalSymptom"/>
    <rdfs:label xml:lang="en">Stress</rdfs:label>
    <rdfs:comment xml:lang="en">
      Overwhelming pressure from external demands, often triggering or
      compounding depression.
      Keyword indicators: stressed, overwhelmed, pressure, can't cope.
    </rdfs:comment>
  </owl:Class>

  <!-- ─── Emotion (affective state — not necessarily clinical) ─ -->

  <owl:Class rdf:about="&mhda;Emotion">
    <rdfs:label xml:lang="en">Emotion</rdfs:label>
    <rdfs:comment xml:lang="en">
      A transient affective state expressed in user text.
      Distinct from clinical Symptom: an emotion is self-reported and
      context-dependent. Multiple co-occurring emotions may aggregate into
      a Symptom over time.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;NegativeEmotion">
    <rdfs:subClassOf rdf:resource="&mhda;Emotion"/>
    <rdfs:label xml:lang="en">Negative Emotion</rdfs:label>
  </owl:Class>

  <owl:Class rdf:about="&mhda;PositiveEmotion">
    <rdfs:subClassOf rdf:resource="&mhda;Emotion"/>
    <rdfs:label xml:lang="en">Positive Emotion</rdfs:label>
    <rdfs:comment xml:lang="en">
      Positive emotions (joy, gratitude, hope) are protective factors
      that can lower depression risk scores.
    </rdfs:comment>
  </owl:Class>

  <!-- ─── Behavior ──────────────────────────────────────────── -->

  <owl:Class rdf:about="&mhda;Behavior">
    <rdfs:label xml:lang="en">Behavior</rdfs:label>
    <rdfs:comment xml:lang="en">
      Observable patterns of action reported in user text.
      Behaviors can be protective (exercise, socialising) or risk-elevating
      (substance use, isolation).
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;RiskBehavior">
    <rdfs:subClassOf rdf:resource="&mhda;Behavior"/>
    <rdfs:label xml:lang="en">Risk Behavior</rdfs:label>
    <rdfs:comment xml:lang="en">
      Behaviors known to increase severity or likelihood of depression.
      Examples: substance abuse, self-harm, extreme sleep disruption.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;ProtectiveBehavior">
    <rdfs:subClassOf rdf:resource="&mhda;Behavior"/>
    <rdfs:label xml:lang="en">Protective Behavior</rdfs:label>
    <rdfs:comment xml:lang="en">
      Behaviors that reduce risk of depression or aid recovery.
      Examples: seeking help, exercise, social connection, professional therapy.
    </rdfs:comment>
  </owl:Class>

  <!-- ─── UserInput ─────────────────────────────────────────── -->

  <owl:Class rdf:about="&mhda;UserInput">
    <rdfs:label xml:lang="en">User Input</rdfs:label>
    <rdfs:comment xml:lang="en">
      A piece of text submitted by a user to the mental health analysis system.
      Corresponds to the 'clean_text' column of the Reddit dataset.
      A single UserInput instance can have multiple Symptoms.
    </rdfs:comment>
    <!-- OWL Restriction: A UserInput must have at least one hasText literal -->
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="&mhda;hasText"/>
        <owl:minCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <!-- OWL Restriction: UserInput with ≥3 symptoms is HighRiskInput -->
  <owl:Class rdf:about="&mhda;HighRiskInput">
    <rdfs:subClassOf rdf:resource="&mhda;UserInput"/>
    <rdfs:label xml:lang="en">High Risk User Input</rdfs:label>
    <rdfs:comment xml:lang="en">
      A UserInput containing 3 or more identified Symptoms.
      Reasoner will classify instances into this class automatically.
    </rdfs:comment>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="&mhda;hasSymptom"/>
        <owl:minCardinality rdf:datatype="&xsd;nonNegativeInteger">3</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="&mhda;ModerateRiskInput">
    <rdfs:subClassOf rdf:resource="&mhda;UserInput"/>
    <rdfs:label xml:lang="en">Moderate Risk User Input</rdfs:label>
    <rdfs:comment xml:lang="en">UserInput with 1 or 2 identified Symptoms.</rdfs:comment>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="&mhda;hasSymptom"/>
        <owl:minCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <!-- ─── MLModel ───────────────────────────────────────────── -->

  <owl:Class rdf:about="&mhda;MLModel">
    <rdfs:label xml:lang="en">Machine Learning Model</rdfs:label>
    <rdfs:comment xml:lang="en">
      A trained machine learning model that produces depression risk predictions.
      In this project: TF-IDF vectoriser + Logistic Regression classifier.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="&mhda;TFIDFLogisticRegression">
    <rdfs:subClassOf rdf:resource="&mhda;MLModel"/>
    <rdfs:label xml:lang="en">TF-IDF + Logistic Regression Classifier</rdfs:label>
    <rdfs:comment xml:lang="en">
      Specific model trained on the Reddit depression dataset (7731 samples,
      binary labels: 0=not depressed, 1=depressed).
      Outputs a continuous risk score in [0.0, 1.0].
    </rdfs:comment>
  </owl:Class>

  <!-- ─── Prediction ────────────────────────────────────────── -->

  <owl:Class rdf:about="&mhda;Prediction">
    <rdfs:label xml:lang="en">Prediction</rdfs:label>
    <rdfs:comment xml:lang="en">
      The output of an MLModel for a given UserInput.
      Carries a numeric riskScore, a categorical riskLevel, and
      links to the conditions and symptoms that justify the prediction.
    </rdfs:comment>
  </owl:Class>

  <!-- ─── ExplainabilityReport ──────────────────────────────── -->

  <owl:Class rdf:about="&mhda;ExplainabilityReport">
    <rdfs:label xml:lang="en">Explainability Report</rdfs:label>
    <rdfs:comment xml:lang="en">
      A human-readable explanation generated by combining ML prediction
      with ontology-based symptom reasoning.
      Example: "High risk detected. Contributing factors: Fatigue, Social Isolation, Hopelessness."
    </rdfs:comment>
  </owl:Class>


  <!-- ============================================================
       O B J E C T   P R O P E R T I E S
       ============================================================ -->

  <!-- indicates: Symptom → MentalHealthCondition -->
  <owl:ObjectProperty rdf:about="&mhda;indicates">
    <rdfs:label xml:lang="en">indicates</rdfs:label>
    <rdfs:comment xml:lang="en">
      A Symptom indicates the possible presence of a MentalHealthCondition.
      This is a weak evidential link; multiple indicating symptoms
      strengthen the inference.
    </rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;Symptom"/>
    <rdfs:range  rdf:resource="&mhda;MentalHealthCondition"/>
  </owl:ObjectProperty>

  <!-- isIndicatedBy: MentalHealthCondition → Symptom (inverse of indicates) -->
  <owl:ObjectProperty rdf:about="&mhda;isIndicatedBy">
    <rdfs:label xml:lang="en">is indicated by</rdfs:label>
    <rdfs:comment xml:lang="en">
      Inverse of 'indicates'. A MentalHealthCondition is indicated by
      one or more Symptoms.
    </rdfs:comment>
    <owl:inverseOf rdf:resource="&mhda;indicates"/>
    <rdfs:domain rdf:resource="&mhda;MentalHealthCondition"/>
    <rdfs:range  rdf:resource="&mhda;Symptom"/>
  </owl:ObjectProperty>

  <!-- causes: Symptom → MentalHealthCondition -->
  <owl:ObjectProperty rdf:about="&mhda;causes">
    <rdfs:label xml:lang="en">causes</rdfs:label>
    <rdfs:comment xml:lang="en">
      A stronger causal claim: this Symptom (or the underlying process that
      produces it) causes or significantly contributes to the condition.
      E.g., chronic SocialIsolation causes Depression.
    </rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;Symptom"/>
    <rdfs:range  rdf:resource="&mhda;MentalHealthCondition"/>
    <rdfs:subPropertyOf rdf:resource="&mhda;indicates"/>
  </owl:ObjectProperty>

  <!-- associated_with: Symptom → MentalHealthCondition -->
  <owl:ObjectProperty rdf:about="&mhda;associated_with">
    <rdfs:label xml:lang="en">associated with</rdfs:label>
    <rdfs:comment xml:lang="en">
      A neutral correlational association between a Symptom and a Condition,
      without implying causation or direct indication.
    </rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;Symptom"/>
    <rdfs:range  rdf:resource="&mhda;MentalHealthCondition"/>
  </owl:ObjectProperty>

  <!-- related_to: Symptom ↔ Symptom (symmetric) -->
  <owl:ObjectProperty rdf:about="&mhda;related_to">
    <rdfs:label xml:lang="en">related to</rdfs:label>
    <rdfs:comment xml:lang="en">
      Two Symptoms co-occur frequently or share an underlying mechanism.
      E.g., Fatigue related_to SleepDisturbance.
      This property is symmetric.
    </rdfs:comment>
    <rdf:type rdf:resource="&owl;SymmetricProperty"/>
    <rdfs:domain rdf:resource="&mhda;Symptom"/>
    <rdfs:range  rdf:resource="&mhda;Symptom"/>
  </owl:ObjectProperty>

  <!-- hasSymptom: UserInput → Symptom -->
  <owl:ObjectProperty rdf:about="&mhda;hasSymptom">
    <rdfs:label xml:lang="en">has symptom</rdfs:label>
    <rdfs:comment xml:lang="en">
      Links a UserInput to a Symptom detected in its text.
      Extracted via keyword matching (NLP pipeline) before ontology reasoning.
    </rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;UserInput"/>
    <rdfs:range  rdf:resource="&mhda;Symptom"/>
  </owl:ObjectProperty>

  <!-- predicts: MLModel → MentalHealthCondition -->
  <owl:ObjectProperty rdf:about="&mhda;predicts">
    <rdfs:label xml:lang="en">predicts</rdfs:label>
    <rdfs:comment xml:lang="en">
      An MLModel predicts the likelihood of a MentalHealthCondition
      for a given UserInput.
    </rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;MLModel"/>
    <rdfs:range  rdf:resource="&mhda;MentalHealthCondition"/>
  </owl:ObjectProperty>

  <!-- generatedFor: Prediction → UserInput -->
  <owl:ObjectProperty rdf:about="&mhda;generatedFor">
    <rdfs:label xml:lang="en">generated for</rdfs:label>
    <rdfs:comment xml:lang="en">Links a Prediction instance to the UserInput it was produced from.</rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;Prediction"/>
    <rdfs:range  rdf:resource="&mhda;UserInput"/>
  </owl:ObjectProperty>

  <!-- generatedBy: Prediction → MLModel -->
  <owl:ObjectProperty rdf:about="&mhda;generatedBy">
    <rdfs:label xml:lang="en">generated by</rdfs:label>
    <rdfs:comment xml:lang="en">Links a Prediction to the MLModel that produced it.</rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;Prediction"/>
    <rdfs:range  rdf:resource="&mhda;MLModel"/>
  </owl:ObjectProperty>

  <!-- predictsCondition: Prediction → MentalHealthCondition -->
  <owl:ObjectProperty rdf:about="&mhda;predictsCondition">
    <rdfs:label xml:lang="en">predicts condition</rdfs:label>
    <rdfs:comment xml:lang="en">The MentalHealthCondition this Prediction is targeting.</rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;Prediction"/>
    <rdfs:range  rdf:resource="&mhda;MentalHealthCondition"/>
  </owl:ObjectProperty>

  <!-- explainedBy: Prediction → ExplainabilityReport -->
  <owl:ObjectProperty rdf:about="&mhda;explainedBy">
    <rdfs:label xml:lang="en">explained by</rdfs:label>
    <rdfs:comment xml:lang="en">Links a Prediction to its ExplainabilityReport.</rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;Prediction"/>
    <rdfs:range  rdf:resource="&mhda;ExplainabilityReport"/>
  </owl:ObjectProperty>

  <!-- highlightsSymptom: ExplainabilityReport → Symptom -->
  <owl:ObjectProperty rdf:about="&mhda;highlightsSymptom">
    <rdfs:label xml:lang="en">highlights symptom</rdfs:label>
    <rdfs:comment xml:lang="en">
      The symptoms cited in the explanation as the most important
      contributing factors to the prediction.
    </rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;ExplainabilityReport"/>
    <rdfs:range  rdf:resource="&mhda;Symptom"/>
  </owl:ObjectProperty>

  <!-- hasEmotion: UserInput → Emotion -->
  <owl:ObjectProperty rdf:about="&mhda;hasEmotion">
    <rdfs:label xml:lang="en">has emotion</rdfs:label>
    <rdfs:comment xml:lang="en">Links a UserInput to an Emotion expressed in the text.</rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;UserInput"/>
    <rdfs:range  rdf:resource="&mhda;Emotion"/>
  </owl:ObjectProperty>

  <!-- hasBehavior: UserInput → Behavior -->
  <owl:ObjectProperty rdf:about="&mhda;hasBehavior">
    <rdfs:label xml:lang="en">has behavior</rdfs:label>
    <rdfs:comment xml:lang="en">Links a UserInput to a Behavior pattern described in the text.</rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;UserInput"/>
    <rdfs:range  rdf:resource="&mhda;Behavior"/>
  </owl:ObjectProperty>

  <!-- comorbidWith: MentalHealthCondition ↔ MentalHealthCondition (symmetric) -->
  <owl:ObjectProperty rdf:about="&mhda;comorbidWith">
    <rdfs:label xml:lang="en">comorbid with</rdfs:label>
    <rdfs:comment xml:lang="en">
      Two conditions frequently co-occur in the same patient population.
      E.g., Depression comorbidWith Anxiety.
    </rdfs:comment>
    <rdf:type rdf:resource="&owl;SymmetricProperty"/>
    <rdfs:domain rdf:resource="&mhda;MentalHealthCondition"/>
    <rdfs:range  rdf:resource="&mhda;MentalHealthCondition"/>
  </owl:ObjectProperty>


  <!-- ============================================================
       D A T A   P R O P E R T I E S
       ============================================================ -->

  <!-- hasText: UserInput → xsd:string -->
  <owl:DatatypeProperty rdf:about="&mhda;hasText">
    <rdfs:label xml:lang="en">has text</rdfs:label>
    <rdfs:comment xml:lang="en">
      The raw or cleaned text of the UserInput.
      Corresponds to the 'clean_text' column in the Reddit dataset.
    </rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;UserInput"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <!-- riskScore: Prediction → xsd:float -->
  <owl:DatatypeProperty rdf:about="&mhda;riskScore">
    <rdfs:label xml:lang="en">risk score</rdfs:label>
    <rdfs:comment xml:lang="en">
      A continuous probability value in [0.0, 1.0] output by the MLModel.
      Represents the model's confidence that the UserInput is from
      a person experiencing depression.
    </rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;Prediction"/>
    <rdfs:range  rdf:resource="&xsd;float"/>
  </owl:DatatypeProperty>

  <!-- riskLevel: Prediction → xsd:string (LOW | MODERATE | HIGH | CRITICAL) -->
  <owl:DatatypeProperty rdf:about="&mhda;riskLevel">
    <rdfs:label xml:lang="en">risk level</rdfs:label>
    <rdfs:comment xml:lang="en">
      A categorical risk tier derived from riskScore and symptom count:
        LOW      — riskScore &lt; 0.35 and 0 symptoms
        MODERATE — riskScore 0.35–0.65 or 1-2 symptoms
        HIGH     — riskScore &gt; 0.65 or ≥3 symptoms
        CRITICAL — SuicidalIdeation detected (immediate intervention required)
    </rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;Prediction"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <!-- symptomCount: Prediction → xsd:integer -->
  <owl:DatatypeProperty rdf:about="&mhda;symptomCount">
    <rdfs:label xml:lang="en">symptom count</rdfs:label>
    <rdfs:comment xml:lang="en">
      The number of distinct Symptoms identified in the corresponding UserInput.
      Used to adjust riskLevel beyond the model's raw riskScore.
    </rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;Prediction"/>
    <rdfs:range  rdf:resource="&xsd;integer"/>
  </owl:DatatypeProperty>

  <!-- explanationText: ExplainabilityReport → xsd:string -->
  <owl:DatatypeProperty rdf:about="&mhda;explanationText">
    <rdfs:label xml:lang="en">explanation text</rdfs:label>
    <rdfs:comment xml:lang="en">
      The human-readable explanation string.
      Example: "High risk due to Fatigue, Social Isolation, and Hopelessness."
    </rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;ExplainabilityReport"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <!-- keywordMatch: Symptom → xsd:string -->
  <owl:DatatypeProperty rdf:about="&mhda;keywordMatch">
    <rdfs:label xml:lang="en">keyword match</rdfs:label>
    <rdfs:comment xml:lang="en">
      The specific word or phrase from the UserInput that triggered
      detection of this Symptom.
    </rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;Symptom"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <!-- modelVersion: MLModel → xsd:string -->
  <owl:DatatypeProperty rdf:about="&mhda;modelVersion">
    <rdfs:label xml:lang="en">model version</rdfs:label>
    <rdfs:domain rdf:resource="&mhda;MLModel"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <!-- trainingAccuracy: MLModel → xsd:float -->
  <owl:DatatypeProperty rdf:about="&mhda;trainingAccuracy">
    <rdfs:label xml:lang="en">training accuracy</rdfs:label>
    <rdfs:domain rdf:resource="&mhda;MLModel"/>
    <rdfs:range  rdf:resource="&xsd;float"/>
  </owl:DatatypeProperty>

  <!-- timestamp: Prediction → xsd:dateTime -->
  <owl:DatatypeProperty rdf:about="&mhda;timestamp">
    <rdfs:label xml:lang="en">timestamp</rdfs:label>
    <rdfs:comment xml:lang="en">Date and time at which the Prediction was generated.</rdfs:comment>
    <rdfs:domain rdf:resource="&mhda;Prediction"/>
    <rdfs:range  rdf:resource="&xsd;dateTime"/>
  </owl:DatatypeProperty>


  <!-- ============================================================
       I N D I V I D U A L S  (A-Box)
       ============================================================ -->

  <!-- ─── The deployed ML model ─────────────────────────────── -->

  <mhda:TFIDFLogisticRegression rdf:about="&mhda;DepressionClassifier_v1">
    <rdfs:label xml:lang="en">Depression Classifier v1</rdfs:label>
    <rdfs:comment xml:lang="en">
      TF-IDF + Logistic Regression model trained on the Reddit depression dataset
      (7,731 samples; ~50/50 class balance).
    </rdfs:comment>
    <mhda:modelVersion>1.0</mhda:modelVersion>
    <mhda:predicts rdf:resource="&mhda;Depression_Condition"/>
  </mhda:TFIDFLogisticRegression>

  <!-- ─── The target condition ──────────────────────────────── -->

  <mhda:Depression rdf:about="&mhda;Depression_Condition">
    <rdfs:label xml:lang="en">Depression (target condition)</rdfs:label>
    <mhda:isIndicatedBy rdf:resource="&mhda;Fatigue_Symptom"/>
    <mhda:isIndicatedBy rdf:resource="&mhda;SocialIsolation_Symptom"/>
    <mhda:isIndicatedBy rdf:resource="&mhda;Hopelessness_Symptom"/>
    <mhda:isIndicatedBy rdf:resource="&mhda;Sadness_Symptom"/>
    <mhda:isIndicatedBy rdf:resource="&mhda;SleepDisturbance_Symptom"/>
    <mhda:isIndicatedBy rdf:resource="&mhda;Anhedonia_Symptom"/>
    <mhda:isIndicatedBy rdf:resource="&mhda;Worthlessness_Symptom"/>
    <mhda:isIndicatedBy rdf:resource="&mhda;SuicidalIdeation_Symptom"/>
    <mhda:comorbidWith rdf:resource="&mhda;Anxiety_Condition"/>
  </mhda:Depression>

  <mhda:Anxiety rdf:about="&mhda;Anxiety_Condition">
    <rdfs:label xml:lang="en">Anxiety (co-morbid condition)</rdfs:label>
    <mhda:comorbidWith rdf:resource="&mhda;Depression_Condition"/>
  </mhda:Anxiety>

  <!-- ─── Canonical symptom individuals ─────────────────────── -->

  <mhda:Fatigue rdf:about="&mhda;Fatigue_Symptom">
    <rdfs:label xml:lang="en">Fatigue Symptom</rdfs:label>
    <rdfs:comment xml:lang="en">Persistent tiredness; "I feel exhausted all the time."</rdfs:comment>
    <mhda:indicates rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;SleepDisturbance_Symptom"/>
    <mhda:related_to rdf:resource="&mhda;Anhedonia_Symptom"/>
    <mhda:keywordMatch>tired</mhda:keywordMatch>
    <mhda:keywordMatch>exhausted</mhda:keywordMatch>
    <mhda:keywordMatch>drained</mhda:keywordMatch>
    <mhda:keywordMatch>no energy</mhda:keywordMatch>
  </mhda:Fatigue>

  <mhda:SocialIsolation rdf:about="&mhda;SocialIsolation_Symptom">
    <rdfs:label xml:lang="en">Social Isolation Symptom</rdfs:label>
    <rdfs:comment xml:lang="en">
      Avoidance of people; "life is so much more peaceful when everyone else is asleep."
      (Directly observed in Reddit dataset.)
    </rdfs:comment>
    <mhda:indicates rdf:resource="&mhda;Depression_Condition"/>
    <mhda:causes   rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;Loneliness_Symptom"/>
    <mhda:related_to rdf:resource="&mhda;Isolation_Symptom"/>
    <mhda:keywordMatch>alone</mhda:keywordMatch>
    <mhda:keywordMatch>isolate</mhda:keywordMatch>
    <mhda:keywordMatch>no friends</mhda:keywordMatch>
    <mhda:keywordMatch>avoid people</mhda:keywordMatch>
  </mhda:SocialIsolation>

  <mhda:Hopelessness rdf:about="&mhda;Hopelessness_Symptom">
    <rdfs:label xml:lang="en">Hopelessness Symptom</rdfs:label>
    <rdfs:comment xml:lang="en">
      "I feel utterly hopeless when I think soon enough I'll have to move out."
      (Observed in Reddit dataset.)
    </rdfs:comment>
    <mhda:indicates rdf:resource="&mhda;Depression_Condition"/>
    <mhda:causes   rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;NegativeThinking_Symptom"/>
    <mhda:related_to rdf:resource="&mhda;SuicidalIdeation_Symptom"/>
    <mhda:keywordMatch>hopeless</mhda:keywordMatch>
    <mhda:keywordMatch>no point</mhda:keywordMatch>
    <mhda:keywordMatch>nothing matters</mhda:keywordMatch>
    <mhda:keywordMatch>futile</mhda:keywordMatch>
  </mhda:Hopelessness>

  <mhda:Sadness rdf:about="&mhda;Sadness_Symptom">
    <rdfs:label xml:lang="en">Sadness Symptom</rdfs:label>
    <rdfs:comment xml:lang="en">Persistent low mood; crying; feeling empty.</rdfs:comment>
    <mhda:indicates rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;Hopelessness_Symptom"/>
    <mhda:keywordMatch>sad</mhda:keywordMatch>
    <mhda:keywordMatch>cry</mhda:keywordMatch>
    <mhda:keywordMatch>miserable</mhda:keywordMatch>
    <mhda:keywordMatch>tearful</mhda:keywordMatch>
  </mhda:Sadness>

  <mhda:SleepDisturbance rdf:about="&mhda;SleepDisturbance_Symptom">
    <rdfs:label xml:lang="en">Sleep Disturbance Symptom</rdfs:label>
    <rdfs:comment xml:lang="en">
      "Instead of sleeping more when depressed, stay up all night to avoid the next day."
      (Observed in Reddit dataset.)
    </rdfs:comment>
    <mhda:indicates rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;Fatigue_Symptom"/>
    <mhda:related_to rdf:resource="&mhda;Avoidance_Symptom"/>
    <mhda:keywordMatch>can't sleep</mhda:keywordMatch>
    <mhda:keywordMatch>insomnia</mhda:keywordMatch>
    <mhda:keywordMatch>sleep all day</mhda:keywordMatch>
    <mhda:keywordMatch>stay up all night</mhda:keywordMatch>
  </mhda:SleepDisturbance>

  <mhda:Anhedonia rdf:about="&mhda;Anhedonia_Symptom">
    <rdfs:label xml:lang="en">Anhedonia Symptom</rdfs:label>
    <rdfs:comment xml:lang="en">
      "I used to enjoy posting but now I can't bring myself to open it."
      (Observed in Reddit dataset.)
    </rdfs:comment>
    <mhda:indicates rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;Fatigue_Symptom"/>
    <mhda:related_to rdf:resource="&mhda;Sadness_Symptom"/>
    <mhda:keywordMatch>no interest</mhda:keywordMatch>
    <mhda:keywordMatch>don't enjoy</mhda:keywordMatch>
    <mhda:keywordMatch>numb</mhda:keywordMatch>
    <mhda:keywordMatch>empty</mhda:keywordMatch>
  </mhda:Anhedonia>

  <mhda:Worthlessness rdf:about="&mhda;Worthlessness_Symptom">
    <rdfs:label xml:lang="en">Worthlessness Symptom</rdfs:label>
    <mhda:indicates rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;Guilt_Symptom"/>
    <mhda:keywordMatch>worthless</mhda:keywordMatch>
    <mhda:keywordMatch>useless</mhda:keywordMatch>
    <mhda:keywordMatch>burden</mhda:keywordMatch>
    <mhda:keywordMatch>failure</mhda:keywordMatch>
  </mhda:Worthlessness>

  <mhda:Guilt rdf:about="&mhda;Guilt_Symptom">
    <rdfs:label xml:lang="en">Guilt Symptom</rdfs:label>
    <mhda:indicates rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;Worthlessness_Symptom"/>
    <mhda:keywordMatch>my fault</mhda:keywordMatch>
    <mhda:keywordMatch>blame myself</mhda:keywordMatch>
    <mhda:keywordMatch>guilty</mhda:keywordMatch>
  </mhda:Guilt>

  <mhda:SuicidalIdeation rdf:about="&mhda;SuicidalIdeation_Symptom">
    <rdfs:label xml:lang="en">Suicidal Ideation Symptom</rdfs:label>
    <rdfs:comment xml:lang="en">
      CRITICAL RISK FLAG. Thoughts of death, suicide, or self-harm.
      Observed in Reddit dataset: "I'll just casually think to myself... fast forward to when I'm dead."
      When this symptom is present, riskLevel must be set to CRITICAL.
    </rdfs:comment>
    <mhda:indicates rdf:resource="&mhda;Depression_Condition"/>
    <mhda:causes   rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;Hopelessness_Symptom"/>
    <mhda:keywordMatch>suicide</mhda:keywordMatch>
    <mhda:keywordMatch>end it</mhda:keywordMatch>
    <mhda:keywordMatch>don't want to live</mhda:keywordMatch>
    <mhda:keywordMatch>kill myself</mhda:keywordMatch>
    <mhda:keywordMatch>overdose</mhda:keywordMatch>
  </mhda:SuicidalIdeation>

  <mhda:NegativeThinking rdf:about="&mhda;NegativeThinking_Symptom">
    <rdfs:label xml:lang="en">Negative Thinking Symptom</rdfs:label>
    <mhda:indicates rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;Hopelessness_Symptom"/>
    <mhda:keywordMatch>hate myself</mhda:keywordMatch>
    <mhda:keywordMatch>dark thoughts</mhda:keywordMatch>
    <mhda:keywordMatch>always fail</mhda:keywordMatch>
    <mhda:keywordMatch>nothing works</mhda:keywordMatch>
  </mhda:NegativeThinking>

  <mhda:Isolation rdf:about="&mhda;Isolation_Symptom">
    <rdfs:label xml:lang="en">Isolation Symptom</rdfs:label>
    <mhda:indicates rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;SocialIsolation_Symptom"/>
    <mhda:related_to rdf:resource="&mhda;Loneliness_Symptom"/>
    <mhda:keywordMatch>isolated</mhda:keywordMatch>
    <mhda:keywordMatch>cut off</mhda:keywordMatch>
  </mhda:Isolation>

  <mhda:Loneliness rdf:about="&mhda;Loneliness_Symptom">
    <rdfs:label xml:lang="en">Loneliness Symptom</rdfs:label>
    <mhda:indicates rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;Isolation_Symptom"/>
    <mhda:keywordMatch>lonely</mhda:keywordMatch>
    <mhda:keywordMatch>no one cares</mhda:keywordMatch>
  </mhda:Loneliness>

  <mhda:Stress rdf:about="&mhda;Stress_Symptom">
    <rdfs:label xml:lang="en">Stress Symptom</rdfs:label>
    <mhda:associated_with rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;Fatigue_Symptom"/>
    <mhda:keywordMatch>stressed</mhda:keywordMatch>
    <mhda:keywordMatch>overwhelmed</mhda:keywordMatch>
    <mhda:keywordMatch>can't cope</mhda:keywordMatch>
  </mhda:Stress>

  <mhda:Avoidance rdf:about="&mhda;Avoidance_Symptom">
    <rdfs:label xml:lang="en">Avoidance Symptom</rdfs:label>
    <mhda:indicates rdf:resource="&mhda;Depression_Condition"/>
    <mhda:related_to rdf:resource="&mhda;SocialIsolation_Symptom"/>
    <mhda:related_to rdf:resource="&mhda;SleepDisturbance_Symptom"/>
    <mhda:keywordMatch>avoid</mhda:keywordMatch>
    <mhda:keywordMatch>hiding</mhda:keywordMatch>
    <mhda:keywordMatch>can't face</mhda:keywordMatch>
  </mhda:Avoidance>

  <!-- ─── Example UserInput (derived from dataset patterns) ─── -->

  <mhda:HighRiskInput rdf:about="&mhda;ExampleInput_HighRisk">
    <rdfs:label xml:lang="en">Example High-Risk Input</rdfs:label>
    <rdfs:comment xml:lang="en">
      Synthetic example modelled on dataset patterns:
      fatigue + hopelessness + isolation → HIGH risk.
    </rdfs:comment>
    <mhda:hasText>Sleep is my greatest escape. When I wake up the very first emotion is misery. I feel utterly hopeless and completely alone.</mhda:hasText>
    <mhda:hasSymptom rdf:resource="&mhda;Fatigue_Symptom"/>
    <mhda:hasSymptom rdf:resource="&mhda;SleepDisturbance_Symptom"/>
    <mhda:hasSymptom rdf:resource="&mhda;Hopelessness_Symptom"/>
    <mhda:hasSymptom rdf:resource="&mhda;Isolation_Symptom"/>
    <mhda:hasSymptom rdf:resource="&mhda;Sadness_Symptom"/>
  </mhda:HighRiskInput>

  <mhda:ModerateRiskInput rdf:about="&mhda;ExampleInput_ModerateRisk">
    <rdfs:label xml:lang="en">Example Moderate-Risk Input</rdfs:label>
    <mhda:hasText>Lately I have been feeling stressed and a bit tired. I don't sleep well but I manage.</mhda:hasText>
    <mhda:hasSymptom rdf:resource="&mhda;Stress_Symptom"/>
    <mhda:hasSymptom rdf:resource="&mhda;Fatigue_Symptom"/>
    <mhda:hasSymptom rdf:resource="&mhda;SleepDisturbance_Symptom"/>
  </mhda:ModerateRiskInput>

  <mhda:UserInput rdf:about="&mhda;ExampleInput_LowRisk">
    <rdfs:label xml:lang="en">Example Low-Risk Input</rdfs:label>
    <mhda:hasText>I had a rough week but my friends helped me through it. Feeling much better now.</mhda:hasText>
  </mhda:UserInput>

  <!-- ─── Example Predictions ──────────────────────────────── -->

  <mhda:Prediction rdf:about="&mhda;Prediction_HighRisk_001">
    <rdfs:label xml:lang="en">Prediction — High Risk Example</rdfs:label>
    <mhda:generatedFor rdf:resource="&mhda;ExampleInput_HighRisk"/>
    <mhda:generatedBy  rdf:resource="&mhda;DepressionClassifier_v1"/>
    <mhda:predictsCondition rdf:resource="&mhda;Depression_Condition"/>
    <mhda:riskScore>0.87</mhda:riskScore>
    <mhda:riskLevel>HIGH</mhda:riskLevel>
    <mhda:symptomCount>5</mhda:symptomCount>
    <mhda:explainedBy rdf:resource="&mhda;Report_HighRisk_001"/>
  </mhda:Prediction>

  <mhda:Prediction rdf:about="&mhda;Prediction_Moderate_002">
    <rdfs:label xml:lang="en">Prediction — Moderate Risk Example</rdfs:label>
    <mhda:generatedFor rdf:resource="&mhda;ExampleInput_ModerateRisk"/>
    <mhda:generatedBy  rdf:resource="&mhda;DepressionClassifier_v1"/>
    <mhda:predictsCondition rdf:resource="&mhda;Depression_Condition"/>
    <mhda:riskScore>0.48</mhda:riskScore>
    <mhda:riskLevel>MODERATE</mhda:riskLevel>
    <mhda:symptomCount>3</mhda:symptomCount>
    <mhda:explainedBy rdf:resource="&mhda;Report_Moderate_002"/>
  </mhda:Prediction>

  <!-- ─── Example Explainability Reports ───────────────────── -->

  <mhda:ExplainabilityReport rdf:about="&mhda;Report_HighRisk_001">
    <rdfs:label xml:lang="en">Explainability Report — High Risk</rdfs:label>
    <mhda:explanationText>
      HIGH risk of depression detected (score: 0.87).
      Contributing factors identified in text: Fatigue, Sleep Disturbance,
      Hopelessness, Isolation, and Sadness (5 symptoms).
      Recommendation: Please consider speaking with a mental health professional.
    </mhda:explanationText>
    <mhda:highlightsSymptom rdf:resource="&mhda;Hopelessness_Symptom"/>
    <mhda:highlightsSymptom rdf:resource="&mhda;Fatigue_Symptom"/>
    <mhda:highlightsSymptom rdf:resource="&mhda;Isolation_Symptom"/>
    <mhda:highlightsSymptom rdf:resource="&mhda;SleepDisturbance_Symptom"/>
    <mhda:highlightsSymptom rdf:resource="&mhda;Sadness_Symptom"/>
  </mhda:ExplainabilityReport>

  <mhda:ExplainabilityReport rdf:about="&mhda;Report_Moderate_002">
    <rdfs:label xml:lang="en">Explainability Report — Moderate Risk</rdfs:label>
    <mhda:explanationText>
      MODERATE risk of depression detected (score: 0.48).
      Contributing factors: Stress, Fatigue, Sleep Disturbance (3 symptoms).
      Recommendation: Monitor wellbeing; consider stress management strategies.
    </mhda:explanationText>
    <mhda:highlightsSymptom rdf:resource="&mhda;Stress_Symptom"/>
    <mhda:highlightsSymptom rdf:resource="&mhda;Fatigue_Symptom"/>
    <mhda:highlightsSymptom rdf:resource="&mhda;SleepDisturbance_Symptom"/>
  </mhda:ExplainabilityReport>


  <!-- ============================================================
       L O G I C A L   R E S T R I C T I O N S  (SWRL-style notes)
       ============================================================

  The following OWL restrictions are embedded on classes above.
  For SWRL rules add these to a rules file in Protégé:

  RULE 1 — HighRiskInput classification:
    UserInput(?u) ∧ hasSymptom(?u, ?s1) ∧ hasSymptom(?u, ?s2) ∧
    hasSymptom(?u, ?s3) ∧ DifferentFrom(?s1,?s2) ∧ DifferentFrom(?s2,?s3)
    → HighRiskInput(?u)

  RULE 2 — Critical override (SuicidalIdeation):
    Prediction(?p) ∧ generatedFor(?p, ?u) ∧
    hasSymptom(?u, SuicidalIdeation_Symptom)
    → riskLevel(?p, "CRITICAL"^^xsd:string)

  RULE 3 — Symptom chain (related symptoms elevate co-inferred symptoms):
    UserInput(?u) ∧ hasSymptom(?u, ?s1) ∧ related_to(?s1, ?s2)
    → hasSymptom(?u, ?s2)
       [applies with confidence weight 0.5]

  RULE 4 — Comorbidity inference:
    Prediction(?p) ∧ predictsCondition(?p, Depression_Condition) ∧
    riskScore(?p, ?rs) ∧ swrlb:greaterThan(?rs, 0.7)
    → predictsCondition(?p, Anxiety_Condition)

  ============================================================ -->

</rdf:RDF>
